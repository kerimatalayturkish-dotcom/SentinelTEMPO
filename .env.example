# ─── Chain & App ───
NEXT_PUBLIC_TEMPO_CHAIN_ID=4217
NEXT_PUBLIC_TEMPO_RPC_URL=https://rpc.tempo.xyz
NEXT_PUBLIC_TEMPO_WS_URL=wss://rpc.tempo.xyz
NEXT_PUBLIC_EXPLORER_URL=https://explore.tempo.xyz
NEXT_PUBLIC_CHAIN_NAME=Tempo
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_PATHUSD_ADDRESS=0x20C000000000000000000000b9537d11c60E8b50
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev-only: a single allowed cross-origin host for Next 16 dev warnings
# (e.g. an ngrok tunnel). Leave blank in production.
NEXT_PUBLIC_DEV_ORIGIN=

# ─── Server Keys (role-separated) ───
# Owner: deploys the contract, sets merkle root, pauses/unpauses. Keep offline after launch.
OWNER_PRIVATE_KEY=
# Server minter: authorised in the contract to call mintForAgent.
SERVER_PRIVATE_KEY=
# Sponsors gas for MPP agent charges (pays fees so agents don't need gas tokens).
FEE_PAYER_KEY=
# Funds the Irys uploader (image + metadata pinning).
IRYS_PRIVATE_KEY=
# Receives pathUSD for every mint. Immutable on-chain.
NFT_TREASURY_WALLET=

# ─── MPP ───
# Optional: only needed if mppx requires signed webhooks in your deployment.
MPP_SECRET_KEY=

# ─── Irys ───
IRYS_RPC_URL=https://rpc.sepolia.org
IRYS_NETWORK=devnet

# ─── Database (Postgres, required) ───
# Used for merkle proofs + refund queue.
DATABASE_URL=postgresql://user:password@host:5432/sentinel_tempo

# ─── Admin dashboard ───
ADMIN_USERNAME=admin
# argon2id hash of the admin password. Generate with:
#   node -e "require('argon2').hash(process.argv[1], {type: 2}).then(console.log)" 'yourPassword'
ADMIN_PASSWORD_HASH=
# HS256 signing secret for the admin session JWT. Must be >= 32 chars.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
